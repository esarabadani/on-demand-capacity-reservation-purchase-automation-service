{
  // -------------------------------------------------------------------------
  // local.settings.json.example
  //
  // Copy this to `local.settings.json` when running the Function App locally
  // with `func start`. That file is git-ignored so real values never leak
  // into the repo.
  //
  // In Azure, these same values are set by Terraform as Function App
  // "app settings" - see the `app_settings` block in infra/main.tf.
  // -------------------------------------------------------------------------
  "IsEncrypted": false,
  "Values": {
    // Local dev uses Azurite (the storage emulator) for AzureWebJobsStorage.
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",

    // Tells the runtime this is a Python Function App.
    "FUNCTIONS_WORKER_RUNTIME": "python",

    // ---- Application settings consumed by cr_config.py ----

    // Azure subscription that owns the reservations resource group.
    "CR_TARGET_SUBSCRIPTION_ID": "00000000-0000-0000-0000-000000000000",

    // Resource group where the Capacity Reservation Group lives.
    "CR_TARGET_RESOURCE_GROUP": "rg-capacity-reservations",

    // Azure region for the reservations. Must be a region where the target
    // SKUs are available for capacity reservation.
    "CR_LOCATION": "westeurope",

    // Name of the Capacity Reservation Group (the "shelf" that holds the
    // per-SKU reservations). Any 1..80-char alphanumeric+hyphen name works.
    "CR_GROUP_NAME": "cr-group-we",

    // Targets: JSON list of {sku, quantity} objects.
    // The bot will keep trying to grow each reservation to `quantity`.
    "CR_TARGETS": "[{\"sku\":\"Standard_NV6ads_A10_v5\",\"quantity\":50},{\"sku\":\"Standard_NV18ads_A10_v5\",\"quantity\":9}]",

    // Table names in the storage account. Defaults are fine; only change
    // these if you deploy multiple bots to the same storage account.
    "CR_STATE_TABLE": "crState",
    "CR_ATTEMPTS_TABLE": "crAttempts",

    // Storage account NAME (not connection string). We authenticate to it
    // with the Function's managed identity, so no keys are needed.
    "CR_STORAGE_ACCOUNT": "yourstorageacct"
  }
}
